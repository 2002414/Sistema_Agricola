<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>

const modalResponder =

document.getElementById(

'modalResponder'

);

modalResponder.addEventListener(

'show.bs.modal',

function(event){

const button =

event.relatedTarget;

const receptor =

button.getAttribute(

'data-receptor'

);

document.getElementById(

'receptor'

).value = receptor;

}

);

</script>

