<?php

session_start();

include("../../Config/conexion.php");

if(!isset($_SESSION['usuario'])){

    header("Location: ../../index.php");

    exit();

}

/* =========================
   MARCAR LEIDOS
========================= */

pg_query_params(

    $conn,

    "
    UPDATE mensajes
    SET leido = TRUE
    WHERE receptor = $1
    ",

    array(
        $_SESSION['id_usuario']
    )

);

$id_usuario = $_SESSION['id_usuario'];

/* =========================
   MENSAJES DEL USUARIO
========================= */

$query = "

SELECT DISTINCT

CASE

WHEN emisor = $1

THEN receptor

ELSE emisor

END AS id_chat,

u.nombre

FROM mensajes

LEFT JOIN usuarios u

ON u.id_usuario =

CASE

WHEN emisor = $1

THEN receptor

ELSE emisor

END

WHERE

emisor = $1

OR

receptor = $1

ORDER BY nombre

";

$resultado = pg_query_params(

    $conn,

    $query,

    array($id_usuario)

);

$resultado = pg_query_params(

    $conn,

    $query,

    array($id_usuario)

);

?>

